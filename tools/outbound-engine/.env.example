# Copy to a file named .env (gitignored) in this folder and fill in what you have.
# NEVER commit real values. Your keys never leave your machine.
#
# ============================================================================
# LIVE MODE — read this before setting anything below to "true"
# ============================================================================
# This build of the Outbound Engine is DRY-RUN ONLY, on purpose:
#   - outbound_engine/signals/visual_visitor.py refuses if VISUAL_VISITOR_LIVE_MODE=true
#   - outbound_engine/load/smartlead.py refuses if SMARTLEAD_LIVE_MODE=true
# Setting these to "true" will NOT make real API calls happen — there is no
# real-API code path in this build at all. It will just make the tool refuse
# to run with a clear error explaining why (see each module's docstring).
# Real live wiring is a future, JD-approved build, gated on a confirmed
# field-by-field wiring session with Bryan Fikes (whose stack this packages).
# ============================================================================

# Smartlead — NOT called in this build regardless of this key's presence.
SMARTLEAD_API_KEY=
SMARTLEAD_LIVE_MODE=false

# Visual Visitor — NOT called in this build regardless of this key's presence.
VISUAL_VISITOR_API_KEY=
VISUAL_VISITOR_LIVE_MODE=false

# Personalization provider: mock (default, no keys needed) | claude | gemini
# claude/gemini shell out to your already-authenticated local CLI session —
# this only generates draft text for YOU to review, it is never an outbound send.
OUTBOUND_LLM_PROVIDER=mock

# Only needed if you don't have the `claude` CLI logged in via subscription auth
# and still want to use OUTBOUND_LLM_PROVIDER=claude (rarely necessary).
ANTHROPIC_API_KEY=
