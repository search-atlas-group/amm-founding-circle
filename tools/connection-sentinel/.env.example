# Copy this file to .env in this folder (gitignored) and fill in ONLY the
# connections you actually use in connections.yaml. Nothing here ever leaves
# your machine -- the sentinel reads these locally to build its own probe
# requests; it never sends your credentials anywhere else.

# --- Search Atlas MCP ---
SEARCHATLAS_API_KEY=

# --- Google Ads (read-only ping) ---
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# --- Google Analytics 4 ---
GA4_ACCESS_TOKEN=
GA4_PROPERTY_ID=

# --- Meta (Facebook Marketing API) ---
META_ACCESS_TOKEN=

# --- CallRail ---
CALLRAIL_API_KEY=
CALLRAIL_ACCOUNT_ID=

# --- Smartlead ---
SMARTLEAD_API_KEY=

# --- ClickUp ---
CLICKUP_API_TOKEN=

# --- Slack ---
SLACK_BOT_TOKEN=

# --- Email alerts (optional -- leave blank to use macOS notifications only) ---
SENTINEL_SMTP_HOST=
SENTINEL_SMTP_PORT=587
SENTINEL_SMTP_USER=
SENTINEL_SMTP_PASS=
SENTINEL_SMTP_FROM=
