<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Content QA — $client_name</title>
<style>
  :root {
    --ok: #1a7f37; --warn: #9a6700; --hold: #b02a2a;
    --bg: #f7f7f8; --card: #ffffff; --border: #e2e2e6; --text: #1f2328;
  }
  body { font-family: -apple-system, "Segoe UI", Helvetica, Arial, sans-serif;
         background: var(--bg); color: var(--text); margin: 0; padding: 2rem; }
  .wrap { max-width: 860px; margin: 0 auto; }
  h1 { font-size: 1.4rem; margin-bottom: 0.25rem; }
  .meta { color: #6e7781; font-size: 0.9rem; margin-bottom: 1.5rem; }
  .verdict { padding: 1rem 1.25rem; border-radius: 10px; font-size: 1.15rem;
             font-weight: 700; margin-bottom: 1.5rem; border: 1px solid var(--border); }
  .verdict.SHIP { background: #e8f5e9; color: var(--ok); border-color: #bfe6c2; }
  .verdict.SHIP-WITH-FIXES { background: #fff8e1; color: var(--warn); border-color: #f0e0a6; }
  .verdict.HOLD { background: #fdecea; color: var(--hold); border-color: #f3c1bd; }
  .verdict .reason { display: block; font-weight: 400; font-size: 0.95rem; margin-top: 0.35rem; }
  section { background: var(--card); border: 1px solid var(--border); border-radius: 10px;
            padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; }
  section h2 { font-size: 1.05rem; margin-top: 0; }
  table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
  td { padding: 0.5rem 0.4rem; border-bottom: 1px solid var(--border); vertical-align: top; }
  tr:last-child td { border-bottom: none; }
  td.empty { color: #6e7781; font-style: italic; }
  .snippet { color: #6e7781; font-size: 0.85rem; }
  .badge { display: inline-block; padding: 0.1rem 0.5rem; border-radius: 999px; font-size: 0.8rem; }
  .badge.verified { background: #e8f5e9; color: var(--ok); }
  .badge.unverifiable { background: #f0f1f3; color: #57606a; }
  .badge.contradicted { background: #fdecea; color: var(--hold); }
  .note { color: var(--warn); }
  footer { color: #6e7781; font-size: 0.8rem; margin-top: 1rem; }
</style>
</head>
<body>
<div class="wrap">
  <h1>Content QA Report</h1>
  <div class="meta">Client: <strong>$client_name</strong> &middot; Draft: $draft_source &middot; Generated $generated_at</div>

  <div class="verdict $verdict_class">
    VERDICT: $verdict
    <span class="reason">$verdict_reason</span>
  </div>

  <section>
    <h2>Grammar / mechanics — $grammar_count issue(s)</h2>
    <table>
      <thead><tr><td><strong>Severity</strong></td><td><strong>Issue</strong></td><td><strong>Suggested fix</strong></td></tr></thead>
      $grammar_rows
    </table>
  </section>

  <section>
    <h2>Voice — $voice_status</h2>
    $voice_block
  </section>

  <section>
    <h2>Facts — $fact_count checkable claim(s)</h2>
    <table>
      <thead><tr><td><strong>Verdict</strong></td><td><strong>Claim</strong></td><td><strong>Reason / source</strong></td></tr></thead>
      $fact_rows
    </table>
  </section>

  $degraded_notes

  <footer>Generated by the Content QA Agent — AMM Founding Circle. Your keys never left your machine.</footer>
</div>
</body>
</html>
