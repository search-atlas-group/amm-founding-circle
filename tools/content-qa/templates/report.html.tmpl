<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Content QA — $client_name</title>
<style>$theme_css</style>
<style>
  .verdict { padding: 14px 18px; border-radius: var(--fc-radius); font-size: 16px;
             font-weight: 700; border: 1px solid var(--fc-border); }
  .verdict.SHIP { background: var(--fc-good-soft); color: var(--fc-good); border-color: var(--fc-good); }
  .verdict.SHIP-WITH-FIXES { background: var(--fc-warn-soft); color: var(--fc-warn); border-color: var(--fc-warn); }
  .verdict.HOLD { background: var(--fc-bad-soft); color: var(--fc-bad); border-color: var(--fc-bad); }
  .verdict .reason { display: block; font-weight: 400; font-size: 13px; margin-top: 5px; }
</style>
</head>
<body class="fc">
<main class="fc-shell">
  <header class="fc-header">
    <h1>Content QA Report</h1>
    <p class="fc-subtitle">Client: <strong>$client_name</strong> &middot; Draft: $draft_source &middot; Generated $generated_at</p>
  </header>

  $kpis

  <div class="fc-card">
    <div class="verdict $verdict_class">
      VERDICT: $verdict
      <span class="reason">$verdict_reason</span>
    </div>
  </div>

  <div class="fc-card">
    <h2>Grammar / mechanics <span class="fc-count">$grammar_count issue(s)</span></h2>
    $grammar_table
  </div>

  <div class="fc-card">
    <h2>Voice <span class="fc-count">$voice_status</span></h2>
    $voice_block
  </div>

  <div class="fc-card">
    <h2>Facts <span class="fc-count">$fact_count checkable claim(s)</span></h2>
    $fact_table
  </div>

  $degraded_notes

  <div class="fc-footer">Content QA Agent · AMM Founding Circle · your keys never left your machine.</div>
</main>
</body>
</html>
