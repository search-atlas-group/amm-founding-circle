# Copy to a file named .env (gitignored) in this folder and fill in what applies.
# NEVER commit real values. Your keys never leave your machine.

# --- Google Ads (optional — only needed for disapproved-ad / paused-campaign /
# broken-final-URL checks). Without these set, Bug Hunter still runs the full
# site crawl + tracking checks and just notes this category was skipped.
#
# How to get these: https://developers.google.com/google-ads/api/docs/get-started/dev-token
# (developer token) + an OAuth2 client (client_id/secret) + a refresh token
# generated once via Google's OAuth flow for your Ads account.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# Only needed if you access client accounts through a manager (MCC) account:
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Delivery (optional — both are opt-in; leave blank to just get the
# terminal output + a local HTML report file).

# Slack: an Incoming Webhook bound to your target channel.
SLACK_WEBHOOK_URL=

# Email: plain SMTP (works with Gmail app passwords, most providers).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=
