# Penny Dashboard — copy this to .env and fill in only what you actually use.
# Nothing here is required to run the tool with manual/CSV ad-spend data.
# Your keys never leave your machine.

# Slack webhook for monthly margin-drop alerts (optional).
PENNY_SLACK_WEBHOOK_URL=

# Email alert (optional) — SMTP creds for the monthly margin-drop alert.
PENNY_ALERT_EMAIL_TO=
PENNY_SMTP_HOST=
PENNY_SMTP_PORT=587
PENNY_SMTP_USER=
PENNY_SMTP_PASSWORD=
PENNY_SMTP_FROM=

# Google Ads API (optional) — only needed if a client in
# config/clients.yaml sets google_ads_customer_id instead of
# manual_spend_csv. The official google-ads Python client reads its own
# google-ads.yaml config file (developer_token / client_id / client_secret
# / refresh_token you generate yourself) — nothing below is read directly
# from this .env; it's documented here so you know it exists. See:
# https://developers.google.com/google-ads/api/docs/client-libs/python/oauth-desktop
