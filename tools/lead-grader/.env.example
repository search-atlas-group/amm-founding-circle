# Copy this file to  .env  (already gitignored repo-wide) and fill in your
# own keys. Your keys never leave your machine — this tool runs locally.

# --- Lead source (v1: CallRail only) ---
CALLRAIL_API_KEY=your-callrail-api-key
CALLRAIL_ACCOUNT_ID=your-callrail-account-id
# Per-client CallRail "company" id goes in clients/<slug>/config.yaml,
# not here — one CallRail account can hold many client companies.

# --- Grading + rubric-wizard LLM (bring your own key, pick ONE) ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# LEAD_GRADER_MODEL=claude-sonnet-4-6

# --- Optional: local Whisper fallback for calls CallRail hasn't
# transcribed yet (off by default — installs a heavy extra dependency,
# see README "Local transcription fallback"). Leave unset to skip it.
# ENABLE_LOCAL_WHISPER_FALLBACK=true

# --- Digest delivery (optional — without these, the digest still prints
# to your terminal and writes an HTML file every run) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=you@example.com
# SMTP_PASSWORD=app-password-not-your-real-password
