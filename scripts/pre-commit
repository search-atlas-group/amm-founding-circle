#!/usr/bin/env bash
# Block commits that contain secrets, internal infra, or known PII patterns.
set -u
PATTERNS='xoxb-[0-9A-Za-z-]{10,}|hooks\.slack\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]{20,}|T60UP6CAW|searchatlasgroup\.slack\.com|devbot\.infra|forge\.internal|\.internal\.|labs\.searchatlas|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----'
staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0
hits=0
while IFS= read -r f; do
  [ -f "$f" ] || continue
  case "$f" in scripts/pre-commit) continue;; esac
  if grep -EnI "$PATTERNS" "$f" >/dev/null 2>&1; then
    echo "BLOCKED: secret/internal pattern in $f"
    grep -EnI "$PATTERNS" "$f" | head -5
    hits=1
  fi
  case "$f" in
    *feed.secrets|*.env|*.secrets) echo "BLOCKED: secret file staged: $f"; hits=1;;
  esac
done <<< "$staged"
if [ "$hits" -ne 0 ]; then
  echo "Pre-commit blocked. Remove the above before committing."
  exit 1
fi
exit 0
