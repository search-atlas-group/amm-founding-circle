<!doctype html>
<html lang="{{ lang | default('en') }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
<meta name="color-scheme" content="light">
<title>{{ title | default('Untitled deck') }}</title>
<style>
/* =============================================================
   Stage — horizontal snap-scroll slide deck.
   Single-file, no external deps, light mode.
   ============================================================= */
:root {
  --ink: #0f172a;
  --ink-soft: #2e3a4d;
  --muted: #5a6470;
  --hairline: rgba(15, 23, 42, 0.08);
  --paper: #fcfcf9;
  --void: #e8e6df;
  --rule: #d8d6cf;
  --accent: {{ accent_color | default('#1d4ed8') }};
  --stat:   {{ stat_color   | default('#c2410c') }};
  --stat-soft: #fff1e8;
  --notes-bg: #f5efde;
  --notes-ink: #4a3a13;
  --notes-rule: #e7dcb8;
  --font: {{ font_stack | default('-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif') }};
  --font-serif: ui-serif, Georgia, "Times New Roman", serif;
  --font-mono:  ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;
}
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; height: 100%; background: var(--void); color: var(--ink); font-family: var(--font); -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; overflow: hidden; }
.skip-link { position: fixed; top: 8px; left: 8px; z-index: 1000; background: var(--ink); color: var(--paper); padding: 8px 12px; border-radius: 4px; font-size: 13px; text-decoration: none; transform: translateY(-200%); transition: transform 150ms ease; }
.skip-link:focus { transform: translateY(0); outline: 2px solid var(--stat); outline-offset: 2px; }
.stage-progress { position: fixed; top: 0; left: 0; height: 3px; width: 0; background: var(--stat); z-index: 50; transition: width 220ms ease; pointer-events: none; }
.stage-deck { display: flex; flex-direction: row; width: 100vw; height: 100vh; overflow-x: auto; overflow-y: hidden; scroll-snap-type: x mandatory; scroll-behavior: smooth; scrollbar-width: none; background: var(--void); }
.stage-deck::-webkit-scrollbar { display: none; }
.slide { flex: 0 0 100vw; height: 100vh; scroll-snap-align: start; scroll-snap-stop: always; display: flex; align-items: center; justify-content: center; padding: 64px 96px; background: var(--paper); position: relative; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
.slide-inner { width: 100%; max-width: 1100px; }
.eyebrow { font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--stat); margin: 0 0 22px; }
.slide h1, .slide h2 { margin: 0 0 28px; line-height: 1.05; letter-spacing: -0.02em; color: var(--ink); font-weight: 700; text-wrap: balance; }
.slide h1 { font-size: clamp(56px, 6.4vw, 72px); }
.slide h2 { font-size: clamp(44px, 5vw, 56px); }
.slide .subtitle { font-size: clamp(20px, 1.9vw, 26px); color: var(--muted); margin: -10px 0 32px; line-height: 1.4; font-weight: 400; text-wrap: balance; }
.slide .body { font-size: clamp(20px, 1.85vw, 28px); line-height: 1.5; color: var(--ink-soft); max-width: 60ch; }
.slide .body p { margin: 0 0 16px; }
.slide .body p:last-child { margin-bottom: 0; }
.slide .body ul, .slide .body ol { margin: 16px 0; padding-left: 1.4em; }
.slide .body li { margin: 10px 0; }
.slide .body li::marker { color: var(--stat); }
.slide .body strong { color: var(--ink); font-weight: 600; }
.slide .body em { font-style: italic; color: var(--ink); }
.slide .body code { background: #efece4; padding: 2px 7px; border-radius: 4px; font-family: var(--font-mono); font-size: 0.82em; }
.slide .body a { color: var(--accent); text-decoration-thickness: 1px; text-underline-offset: 3px; }
.slide.title-slide { background: linear-gradient(180deg, #fcfcf9 0%, #f6f3eb 100%); }
.slide.title-slide .slide-inner { border-left: 3px solid var(--stat); padding-left: 28px; }
.slide.title-slide h1 { font-size: clamp(64px, 7.6vw, 88px); margin-bottom: 20px; }
.slide.title-slide .subtitle { font-size: clamp(22px, 2.2vw, 30px); margin-top: 12px; }
.slide.big-stat { text-align: center; }
.slide.big-stat .slide-inner { display: flex; flex-direction: column; align-items: center; }
.slide.big-stat .eyebrow { color: var(--muted); }
.slide.big-stat .stat-context { font-size: clamp(22px, 2vw, 28px); color: var(--ink-soft); margin: 0 0 24px; font-weight: 500; max-width: 24ch; }
.slide.big-stat .stat-number { font-size: clamp(96px, 14vw, 168px); font-weight: 800; color: var(--stat); line-height: 0.95; letter-spacing: -0.055em; font-variant-numeric: tabular-nums lining-nums; margin: 8px 0; }
.slide.big-stat .stat-label { font-size: clamp(20px, 1.9vw, 26px); color: var(--muted); margin-top: 18px; font-weight: 500; max-width: 32ch; }
.slide.big-stat .body { margin: 32px auto 0; text-align: left; max-width: 48ch; }
.slide.quote-slide { background: linear-gradient(180deg, var(--paper) 0%, var(--stat-soft) 100%); }
.slide.quote-slide .slide-inner { max-width: 980px; }
.slide.quote-slide .quote-body { font-family: var(--font-serif); font-size: clamp(32px, 4.4vw, 56px); line-height: 1.2; font-style: italic; color: var(--ink); letter-spacing: -0.01em; margin: 0 0 28px; text-wrap: balance; }
.slide.quote-slide .quote-body::before { content: "\201C"; margin-right: 4px; color: var(--stat); }
.slide.quote-slide .quote-body::after  { content: "\201D"; margin-left: 4px;  color: var(--stat); }
.slide.quote-slide .quote-attr { font-size: clamp(15px, 1.3vw, 18px); color: var(--muted); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 600; overflow-wrap: anywhere; max-width: 60ch; }
.pull-quote { margin: 28px 0 0; padding: 24px 28px; background: var(--stat-soft); border-left: 4px solid var(--stat); border-radius: 4px; font-family: var(--font-serif); font-style: italic; font-size: clamp(22px, 2.2vw, 30px); line-height: 1.35; color: var(--ink); max-width: 80ch; }
.pull-quote .attr { display: block; margin-top: 14px; font-size: 13px; font-style: normal; font-family: var(--font); color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; overflow-wrap: anywhere; }
.slide.image-slide { padding: 48px 60px; }
.slide.image-slide .slide-inner { display: flex; flex-direction: column; align-items: center; max-width: 1300px; }
.slide.image-slide figure { margin: 0; width: 100%; text-align: center; }
.slide.image-slide img { display: block; max-width: 100%; max-height: 70vh; height: auto; margin: 0 auto; border-radius: 6px; box-shadow: 0 12px 32px rgba(15, 23, 42, 0.12); background: #fff; }
.slide.image-slide figcaption { margin-top: 20px; font-size: clamp(15px, 1.3vw, 18px); color: var(--muted); text-align: center; max-width: 70ch; }
.slide.closing { background: #0f172a; color: #f8fafc; border-color: rgba(255,255,255,0.06); }
.slide.closing h1, .slide.closing h2 { color: #fcfcf9; }
.slide.closing h2 { font-size: clamp(48px, 5.6vw, 64px); }
.slide.closing .body { color: #cbd5e1; }
.slide.closing .body strong { color: #fcfcf9; }
.slide.closing .eyebrow { color: #fdba74; }
.slide.closing .subtitle { color: #94a3b8; }
.slide img:not(.image-slide img) { max-width: 100%; max-height: 60vh; height: auto; display: block; margin: 18px auto; border-radius: 4px; }
.stage-counter { position: fixed; right: 22px; bottom: 18px; z-index: 40; font-size: 13px; font-variant-numeric: tabular-nums; color: var(--muted); background: rgba(252, 252, 249, 0.92); padding: 7px 14px; border: 1px solid var(--rule); border-radius: 999px; letter-spacing: 0.06em; user-select: none; backdrop-filter: blur(4px); }
.presenter-badge { position: fixed; top: 14px; right: 22px; z-index: 45; display: none; background: var(--stat); color: #fff; font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; padding: 5px 11px; border-radius: 3px; }
body.presenter .presenter-badge { display: block; }
.stage-timer { position: fixed; top: 14px; left: 22px; z-index: 45; display: none; font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-size: 18px; font-weight: 600; color: var(--ink); background: rgba(252, 252, 249, 0.92); padding: 6px 14px; border: 1px solid var(--rule); border-radius: 4px; letter-spacing: 0.04em; backdrop-filter: blur(4px); }
body.timer .stage-timer { display: block; }
.speaker-notes { display: none; position: fixed; left: 50%; transform: translateX(-50%); bottom: 24px; width: min(720px, calc(100vw - 48px)); background: var(--notes-bg); border: 1px solid var(--notes-rule); border-radius: 8px; padding: 18px 22px; font-size: 19px; line-height: 1.55; color: var(--notes-ink); box-shadow: 0 8px 28px rgba(15, 23, 42, 0.15); z-index: 42; }
.speaker-notes-label { display: block; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #8a6d2e; margin-bottom: 8px; }
body.presenter .speaker-notes.is-current { display: block; }
body.presenter .slide { padding-bottom: 200px; }
.stage-veil { position: fixed; inset: 0; z-index: 100; background: #000; opacity: 0; pointer-events: none; transition: opacity 200ms ease; }
body.blackout .stage-veil { opacity: 1; pointer-events: auto; background: #000; }
body.whiteout .stage-veil { opacity: 1; pointer-events: auto; background: #fff; }
.stage-help { display: none; position: fixed; inset: 0; z-index: 110; background: rgba(15, 23, 42, 0.88); align-items: center; justify-content: center; padding: 40px; }
body.help .stage-help { display: flex; }
.stage-help-panel { background: var(--paper); color: var(--ink); border-radius: 10px; padding: 32px 40px; max-width: 520px; width: 100%; box-shadow: 0 24px 60px rgba(0, 0, 0, 0.4); }
.stage-help-panel h3 { margin: 0 0 18px; font-size: 22px; letter-spacing: -0.01em; }
.stage-help-panel dl { display: grid; grid-template-columns: max-content 1fr; gap: 10px 22px; margin: 0; font-size: 15px; line-height: 1.4; }
.stage-help-panel dt { font-family: var(--font-mono); font-size: 13px; background: #efece4; padding: 3px 9px; border-radius: 4px; align-self: start; color: var(--ink); }
.stage-help-panel dd { margin: 0; color: var(--ink-soft); align-self: center; }
.stage-help-hint { margin-top: 20px; font-size: 12px; color: var(--muted); text-align: center; }
body.overview { overflow: auto; }
body.overview .stage-deck { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 22px; padding: 48px 32px; width: 100vw; height: 100vh; overflow: auto; scroll-snap-type: none; background: var(--void); }
body.overview .slide { flex: initial; width: 100%; height: 220px; padding: 18px; border-radius: 8px; border: 2px solid transparent; cursor: pointer; overflow: hidden; align-items: flex-start; justify-content: flex-start; box-shadow: 0 4px 16px rgba(15, 23, 42, 0.08); transition: transform 120ms ease, border-color 120ms ease; position: relative; }
body.overview .slide:hover { border-color: var(--accent); transform: translateY(-2px); }
body.overview .slide.is-current { border-color: var(--stat); }
body.overview .slide.is-next::after { content: "NEXT"; position: absolute; top: 8px; right: 8px; font-size: 10px; font-weight: 700; letter-spacing: 0.18em; background: var(--accent); color: #fff; padding: 3px 7px; border-radius: 3px; }
body.overview .slide-inner { transform: scale(0.42); transform-origin: top left; width: 240%; will-change: transform; pointer-events: none; }
body.overview .speaker-notes, body.overview .stage-counter, body.overview .stage-progress, body.overview .stage-timer, body.overview .presenter-badge { display: none !important; }
.slide.empty-deck { background: var(--paper); text-align: center; }
.slide.empty-deck h2 { font-size: 36px; color: var(--muted); font-weight: 500; }
.slide.empty-deck .body { color: var(--muted); }
@media (max-width: 1024px) and (min-width: 641px) {
  .slide { padding: 48px 56px; }
  .slide h1 { font-size: 56px; }
  .slide h2 { font-size: 44px; }
  .slide .body { font-size: 22px; }
  .slide.big-stat .stat-number { font-size: clamp(80px, 18vw, 130px); }
  .slide.title-slide h1 { font-size: 64px; }
  .slide.quote-slide .quote-body { font-size: 40px; }
  .stage-help-panel dl { grid-template-columns: 1fr; }
}
@media (max-width: 640px) {
  html, body { overflow: auto; }
  .stage-deck { flex-direction: column; height: auto; overflow-x: hidden; overflow-y: auto; scroll-snap-type: y mandatory; }
  .slide { flex: 0 0 100svh; width: 100vw; height: 100svh; padding: 32px 22px; }
  .slide h1 { font-size: 38px; }
  .slide h2 { font-size: 28px; }
  .slide .body { font-size: 17px; line-height: 1.5; }
  .slide.title-slide h1 { font-size: 44px; }
  .slide.title-slide .slide-inner { padding-left: 16px; border-left-width: 2px; }
  .slide.big-stat .stat-number { font-size: clamp(72px, 24vw, 110px); }
  .slide.big-stat .stat-label { font-size: 17px; }
  .slide.quote-slide .quote-body { font-size: 24px; }
  .pull-quote { font-size: 17px; padding: 16px 18px; }
  .slide.closing h2 { font-size: 32px; }
  .stage-counter { right: 12px; bottom: 12px; font-size: 12px; padding: 5px 10px; }
  .stage-timer { left: 12px; top: 10px; font-size: 14px; }
  body.presenter .slide { padding-bottom: 160px; }
  .speaker-notes { font-size: 15px; padding: 12px 16px; }
}
@media (prefers-reduced-motion: reduce) {
  .stage-deck { scroll-behavior: auto; scroll-snap-type: none; }
  .stage-progress, .stage-veil, .speaker-notes { transition: none; }
  body.overview .slide { transition: none; }
}
@media print {
  @page { size: landscape; margin: 14mm; }
  html, body { height: auto; overflow: visible; background: #fff; }
  .skip-link, .stage-progress, .stage-counter, .stage-timer, .presenter-badge, .stage-veil, .stage-help { display: none !important; }
  .stage-deck { display: block; width: auto; height: auto; overflow: visible; background: #fff; }
  .slide { width: 100%; height: auto; min-height: calc(100vh - 28mm); page-break-after: always; break-after: page; padding: 24px 32px; border: none; background: #fff; box-shadow: none; display: block; }
  .slide:last-child { page-break-after: auto; break-after: auto; }
  .slide.closing { background: #0f172a !important; color: #f8fafc !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; color-adjust: exact; }
  .slide-inner { max-width: 100%; }
  .slide h1 { font-size: 44pt; }
  .slide h2 { font-size: 32pt; }
  .slide .body { font-size: 14pt; max-width: none; }
  .slide.big-stat .stat-number { font-size: 96pt; }
  .slide.quote-slide .quote-body { font-size: 28pt; }
  .speaker-notes { display: block !important; position: static; transform: none; width: 100%; margin: 32px 0 0; background: #fff; border: 1px solid #999; border-radius: 0; padding: 12px 16px; font-size: 11pt; color: #333; box-shadow: none; }
  .speaker-notes-label { color: #666; }
  body.overview .stage-deck { display: block; }
  body.overview .slide { transform: none; height: auto; }
  body.overview .slide-inner { transform: none; width: 100%; pointer-events: auto; }
}
noscript { display: block; position: fixed; top: 0; left: 0; right: 0; background: var(--stat); color: #fff; text-align: center; padding: 8px 16px; font-size: 13px; font-weight: 600; z-index: 200; }
</style>
</head>
<body{% if presenter_default | default(false) %} class="presenter"{% endif %}>

<noscript>This deck reads top-to-bottom without JavaScript. Keyboard shortcuts and presenter mode require JS.</noscript>

<a href="#slide-1" class="skip-link">Skip deck chrome to first slide</a>

{% if show_progress | default(true) %}<div class="stage-progress" id="stageProgress" aria-hidden="true" style="width:{% if slides and slides|length > 0 %}{{ (100 / (slides|length)) | round(2) }}{% else %}0{% endif %}%"></div>{% endif %}

<div class="presenter-badge" aria-hidden="true">Presenter</div>
<div class="stage-timer" id="stageTimer" aria-hidden="true">00:00</div>

<main class="stage-deck" id="stageDeck" role="region" aria-roledescription="slide deck" aria-label="{{ title | default('Presentation') }}" tabindex="0">
{% if not slides or slides | length == 0 %}
  <section class="slide empty-deck" id="slide-1" role="region" aria-roledescription="slide" aria-label="Empty deck">
    <div class="slide-inner">
      <div class="eyebrow">Stage</div>
      <h2>This deck has no slides yet.</h2>
      <div class="body"><p>Pass a non-empty <code>slides</code> list to the renderer.</p></div>
    </div>
  </section>
{% else %}
{% for s in slides %}
  {% set raw_kind = s.kind | default('content') %}
  {% set known    = ['title', 'big_stat', 'content', 'quote', 'image', 'closing'] %}
  {% set kind     = raw_kind if raw_kind in known else 'content' %}
  {% set slide_classes = {'title': 'title-slide', 'big_stat': 'big-stat', 'quote': 'quote-slide', 'image': 'image-slide', 'closing': 'closing', 'content': ''} %}
  <section class="slide {{ slide_classes[kind] }}"
           id="slide-{{ loop.index }}"
           data-index="{{ loop.index }}"
           role="region"
           aria-roledescription="slide"
           aria-label="Slide {{ loop.index }} of {{ slides | length }}{% if s.title %}: {{ s.title }}{% endif %}">
    <div class="slide-inner">
      {% if s.eyebrow %}<div class="eyebrow">{{ s.eyebrow }}</div>{% endif %}

      {% if kind == 'title' %}
        {% if s.title %}<h1>{{ s.title }}</h1>{% endif %}
        {% if s.subtitle %}<div class="subtitle">{{ s.subtitle }}</div>{% endif %}

      {% elif kind == 'big_stat' %}
        {% if s.title %}<div class="stat-context">{{ s.title }}</div>{% endif %}
        <div class="stat-number">{{ s.big_stat | default('—') }}</div>
        {% if s.big_stat_label %}<div class="stat-label">{{ s.big_stat_label }}</div>{% endif %}
        {% if s.body_html %}<div class="body">{{ s.body_html | safe }}</div>{% endif %}

      {% elif kind == 'quote' %}
        {% if s.title %}<h2 style="margin-bottom:36px;">{{ s.title }}</h2>{% endif %}
        <div class="quote-body">{{ s.pull_quote | default(s.body_html | default('')) | safe }}</div>
        {% if s.pull_quote_attr %}<div class="quote-attr">— {{ s.pull_quote_attr }}</div>{% endif %}

      {% elif kind == 'image' %}
        {% if s.title %}<h2 style="margin-bottom:24px;text-align:center;">{{ s.title }}</h2>{% endif %}
        <figure>
          {% if s.image_src %}<img src="{{ s.image_src }}" alt="{{ s.image_alt | default(s.title | default('Slide image')) }}">{% endif %}
          {% if s.image_caption %}<figcaption>{{ s.image_caption }}</figcaption>{% endif %}
        </figure>
        {% if s.body_html %}<div class="body" style="margin-top:24px;text-align:center;max-width:none;">{{ s.body_html | safe }}</div>{% endif %}

      {% else %}{# content + closing + any unknown kind fall through to here #}
        {% if s.title %}<h2>{{ s.title }}</h2>{% endif %}
        {% if s.subtitle %}<div class="subtitle">{{ s.subtitle }}</div>{% endif %}
        {% if s.body_html %}<div class="body">{{ s.body_html | safe }}</div>{% endif %}
        {% if s.pull_quote %}
          <div class="pull-quote">{{ s.pull_quote }}
            {% if s.pull_quote_attr %}<span class="attr">— {{ s.pull_quote_attr }}</span>{% endif %}
          </div>
        {% endif %}
      {% endif %}
    </div>
    {% if s.speaker_notes %}
      <aside class="speaker-notes" data-for-slide="{{ loop.index }}" role="note" aria-label="Speaker notes for slide {{ loop.index }}">
        <span class="speaker-notes-label">Speaker notes · slide {{ loop.index }}</span>
        {{ s.speaker_notes }}
      </aside>
    {% endif %}
  </section>
{% endfor %}
{% endif %}
</main>

<div class="stage-veil" aria-hidden="true"></div>

<div class="stage-help" role="dialog" aria-modal="true" aria-labelledby="stageHelpTitle" aria-hidden="true">
  <div class="stage-help-panel">
    <h3 id="stageHelpTitle">Keyboard shortcuts</h3>
    <dl>
      <dt>→ Space PgDn</dt><dd>Next slide</dd>
      <dt>← PgUp</dt><dd>Previous slide</dd>
      <dt>Home / End</dt><dd>First / last slide</dd>
      <dt>O / Esc</dt><dd>Overview (thumbnail grid)</dd>
      <dt>N</dt><dd>Toggle speaker notes</dd>
      <dt>T</dt><dd>Toggle elapsed timer · Shift+T resets</dd>
      <dt>B</dt><dd>Blackout screen</dd>
      <dt>W</dt><dd>Whiteout screen</dd>
      <dt>F</dt><dd>Fullscreen</dd>
      <dt>?</dt><dd>Toggle this help</dd>
    </dl>
    <div class="stage-help-hint">Press <kbd>?</kbd> or <kbd>Esc</kbd> to close</div>
  </div>
</div>

{% if show_counter | default(true) %}
<div class="stage-counter" role="status" aria-live="polite" aria-atomic="true">
  <span id="stageNow">1</span> / <span id="stageTotal">{{ slides | length if slides else 0 }}</span>
</div>
{% endif %}

<script>
(function () {
  'use strict';
  var deck     = document.getElementById('stageDeck');
  var progress = document.getElementById('stageProgress');
  var nowEl    = document.getElementById('stageNow');
  var timerEl  = document.getElementById('stageTimer');
  if (!deck) return;
  var slides = Array.prototype.slice.call(deck.querySelectorAll('.slide'));
  var total  = slides.length;
  if (total === 0) return;
  var idx = 0;
  var pendingFrame = null;
  var timerStart = null;
  var timerInterval = null;

  function clampIdx(i) { return Math.max(0, Math.min(total - 1, i)); }

  function paintProgress() {
    if (!progress) return;
    progress.style.width = (((idx + 1) / total) * 100) + '%';
  }

  function updateCurrent() {
    if (nowEl) nowEl.textContent = String(idx + 1);
    if (pendingFrame) cancelAnimationFrame(pendingFrame);
    pendingFrame = requestAnimationFrame(paintProgress);
    slides.forEach(function (s, i) {
      s.classList.toggle('is-current', i === idx);
      s.classList.toggle('is-next', i === idx + 1);
    });
    // attach is-current to the matching notes pane
    var notes = document.querySelectorAll('.speaker-notes');
    notes.forEach(function (n) {
      n.classList.toggle('is-current', Number(n.getAttribute('data-for-slide')) === idx + 1);
    });
  }

  function goto(i, smooth) {
    idx = clampIdx(i);
    var target = slides[idx];
    if (document.body.classList.contains('overview')) {
      document.body.classList.remove('overview');
      requestAnimationFrame(function () {
        target.scrollIntoView({ behavior: 'auto', inline: 'start', block: 'start' });
      });
    } else {
      target.scrollIntoView({ behavior: smooth === false ? 'auto' : 'smooth', inline: 'start', block: 'start' });
    }
    updateCurrent();
  }

  /* ---- IntersectionObserver: one observer for the whole deck ---- */
  var io = new IntersectionObserver(function (entries) {
    var best = null, bestRatio = 0;
    entries.forEach(function (e) {
      if (e.intersectionRatio > bestRatio) { bestRatio = e.intersectionRatio; best = e.target; }
    });
    if (best && bestRatio > 0.55) {
      var newIdx = slides.indexOf(best);
      if (newIdx !== -1 && newIdx !== idx) { idx = newIdx; updateCurrent(); }
    }
  }, { root: deck, threshold: [0.25, 0.55, 0.85] });
  slides.forEach(function (s) { io.observe(s); });

  /* ---- Timer ---- */
  function fmtTime(ms) {
    var s = Math.floor(ms / 1000);
    var h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
    var pad = function (n) { return n < 10 ? '0' + n : '' + n; };
    return h > 0 ? (h + ':' + pad(m) + ':' + pad(sec)) : (pad(m) + ':' + pad(sec));
  }
  function startTimer() {
    if (timerInterval) return;
    if (!timerStart) timerStart = Date.now();
    timerInterval = setInterval(function () {
      if (timerEl) timerEl.textContent = fmtTime(Date.now() - timerStart);
    }, 250);
  }
  function stopTimer() { if (timerInterval) { clearInterval(timerInterval); timerInterval = null; } }
  function resetTimer() { timerStart = Date.now(); if (timerEl) timerEl.textContent = '00:00'; }

  function toggleTimer() {
    document.body.classList.toggle('timer');
    if (document.body.classList.contains('timer')) { resetTimer(); startTimer(); }
    else { stopTimer(); }
  }

  /* ---- Escape layering ---- */
  function escHandler() {
    if (document.body.classList.contains('help'))      { document.body.classList.remove('help'); return; }
    if (document.body.classList.contains('whiteout'))  { document.body.classList.remove('whiteout'); return; }
    if (document.body.classList.contains('blackout'))  { document.body.classList.remove('blackout'); return; }
    if (document.body.classList.contains('presenter')) { document.body.classList.remove('presenter'); return; }
    if (document.body.classList.contains('overview'))  { document.body.classList.remove('overview'); goto(idx, false); return; }
    if (document.fullscreenElement) { document.exitFullscreen && document.exitFullscreen(); return; }
  }

  /* ---- Keyboard ---- */
  document.addEventListener('keydown', function (e) {
    var tag = e.target && e.target.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || e.isComposing) return;
    if (e.metaKey || e.ctrlKey || e.altKey) return;

    switch (e.key) {
      case 'ArrowRight': case ' ': case 'PageDown': case 'Enter':
        e.preventDefault(); goto(idx + 1); break;
      case 'ArrowLeft': case 'PageUp':
        e.preventDefault(); goto(idx - 1); break;
      case 'Home': e.preventDefault(); goto(0); break;
      case 'End':  e.preventDefault(); goto(total - 1); break;
      case 'Escape': e.preventDefault(); escHandler(); break;
      case 'o': case 'O':
        e.preventDefault();
        document.body.classList.toggle('overview');
        if (!document.body.classList.contains('overview')) goto(idx, false);
        break;
      case 'n': case 'N': e.preventDefault(); document.body.classList.toggle('presenter'); break;
      case 'b': case 'B':
        e.preventDefault();
        document.body.classList.remove('whiteout');
        document.body.classList.toggle('blackout');
        break;
      case 'w': case 'W':
        e.preventDefault();
        document.body.classList.remove('blackout');
        document.body.classList.toggle('whiteout');
        break;
      case 't':
        e.preventDefault(); toggleTimer(); break;
      case 'T':
        e.preventDefault();
        if (e.shiftKey) { resetTimer(); }
        else { toggleTimer(); }
        break;
      case 'f': case 'F':
        e.preventDefault();
        if (!document.fullscreenElement) { document.documentElement.requestFullscreen && document.documentElement.requestFullscreen(); }
        else { document.exitFullscreen && document.exitFullscreen(); }
        break;
      case '?': case '/':
        e.preventDefault(); document.body.classList.toggle('help'); break;
    }
  });

  /* ---- Delegated click for overview thumbnails ---- */
  deck.addEventListener('click', function (e) {
    if (!document.body.classList.contains('overview')) return;
    var section = e.target.closest('.slide');
    if (!section) return;
    var i = slides.indexOf(section);
    if (i !== -1) goto(i, false);
  });

  /* ---- Init ---- */
  updateCurrent();
})();
</script>
</body>
</html>
