{# Timeline archetype — chronological-narrative report.
   Required: title, events[]
   Optional: subtitle, eyebrow, timezone (default "UTC"), generated_at,
             start_metric, end_metric, trend_summary, series_sparkline_svg
   Event:    date (ISO), title, kind (incident|release|milestone|anomaly|note),
             body_html, time, end_date (for ranges),
             short_date, full_date, day_offset (precomputed by caller, optional),
             metrics[], quote{speaker,text},
             before_after{metric,before,after,unit,caption},
             sparkline_svg, sparkline_caption #}
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<style>
:root {
  --tl-spine: 96px;
  --tl-content-max: 800px;
  --tl-gap: 24px;
  --tl-radius: 10px;
  --tl-radius-sm: 6px;
  --tl-bg: #ffffff;
  --tl-bg-soft: #f7f8fa;
  --tl-bg-sunk: #f1f3f6;
  --tl-text: #14181f;
  --tl-text-soft: #3b4452;
  --tl-muted: #6b7280;
  --tl-border: #e3e6ec;
  --tl-border-strong: #c8ced8;
  --tl-incident:  #d62828;
  --tl-release:   #1a5fb4;
  --tl-milestone: #2e7d32;
  --tl-anomaly:   #d97706;
  --tl-note:      #5b6472;
  --tl-up: #2e7d32;
  --tl-down: #d62828;
  --tl-flat: #6b7280;
  --tl-body-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --tl-mono-font: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  --tl-display-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
}
* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { margin: 0; font-family: var(--tl-body-font); font-size: 15px; line-height: 1.6; color: var(--tl-text); background: var(--tl-bg); -webkit-font-smoothing: antialiased; text-rendering: optimizeLegibility; }
.tl-skip { position: absolute; left: -9999px; top: 8px; background: var(--tl-text); color: #fff; padding: 8px 12px; border-radius: 6px; font-size: 13px; font-weight: 600; text-decoration: none; z-index: 200; }
.tl-skip:focus { left: 8px; }
.tl-progress { position: fixed; top: 0; left: 0; right: 0; height: 3px; z-index: 100; background: transparent; pointer-events: none; }
.tl-progress > span { display: block; height: 100%; width: 0%; background: var(--tl-text); transition: width 0.08s linear; }
.tl-shell { max-width: calc(var(--tl-spine) + var(--tl-content-max) + 96px); margin: 0 auto; padding: 40px 32px 96px; }
.tl-doc-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; flex-wrap: wrap; padding-bottom: 20px; margin-bottom: 24px; border-bottom: 1px solid var(--tl-border); }
.tl-doc-eyebrow { font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--tl-muted); margin: 0 0 8px; }
.tl-doc-title { font-family: var(--tl-display-font); font-size: 30px; font-weight: 700; margin: 0 0 4px; line-height: 1.15; letter-spacing: -0.01em; }
.tl-doc-subtitle { font-size: 15px; color: var(--tl-text-soft); margin: 0; max-width: 60ch; }
.tl-doc-meta { font-size: 12px; color: var(--tl-muted); text-align: right; line-height: 1.5; }
.tl-doc-meta .tl-tz { display: inline-block; margin-top: 2px; padding: 1px 6px; border: 1px solid var(--tl-border); border-radius: 4px; font-family: var(--tl-mono-font); font-size: 11px; }
.tl-bookend { display: grid; grid-template-columns: 1fr auto 1fr; gap: 16px 20px; align-items: center; padding: 20px 24px; margin: 0 0 32px; border: 1px solid var(--tl-border); background: var(--tl-bg-soft); border-radius: var(--tl-radius); }
.tl-bookend-stat { display: flex; flex-direction: column; gap: 4px; }
.tl-bookend-stat.is-right { align-items: flex-end; text-align: right; }
.tl-bookend-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--tl-muted); font-weight: 700; }
.tl-bookend-value { font-size: 28px; font-weight: 700; font-variant-numeric: tabular-nums; line-height: 1.05; }
.tl-bookend-unit { font-size: 14px; color: var(--tl-muted); font-weight: 500; margin-left: 4px; }
.tl-bookend-mid { display: flex; flex-direction: column; align-items: center; gap: 2px; color: var(--tl-muted); }
.tl-bookend-mid .tl-bookend-arrow { font-size: 22px; line-height: 1; }
.tl-bookend-mid .tl-bookend-span { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; }
.tl-spark-wide { grid-column: 1 / -1; padding-top: 4px; }
.tl-spark-wide svg { display: block; width: 100%; height: 52px; }
.tl-bookend-trend { grid-column: 1 / -1; margin: 0; padding-top: 14px; font-size: 14px; color: var(--tl-text); border-top: 1px dashed var(--tl-border); }
.tl-bookend-trend strong { color: var(--tl-text); font-weight: 700; }
.tl-track { position: relative; list-style: none; padding: 0; margin: 0; }
.tl-track::before { content: ""; position: absolute; left: calc(var(--tl-spine) - 1px); top: 8px; bottom: 8px; width: 2px; background: linear-gradient(to bottom, transparent 0, var(--tl-border) 12px, var(--tl-border) calc(100% - 12px), transparent 100%); }
.tl-event { display: grid; grid-template-columns: var(--tl-spine) 1fr; gap: var(--tl-gap); padding: 20px 0 24px; position: relative; scroll-margin-top: 24px; }
.tl-event-date { text-align: right; padding-right: 20px; position: relative; padding-top: 2px; }
.tl-event-date-short { font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; line-height: 1.2; color: var(--tl-text); }
.tl-event-date-full { font-size: 11px; color: var(--tl-muted); margin-top: 4px; line-height: 1.4; font-variant-numeric: tabular-nums; }
.tl-event-date-range { display: inline-block; margin-top: 4px; padding: 1px 6px; font-size: 10px; font-weight: 700; letter-spacing: 0.06em; color: var(--tl-muted); border: 1px solid var(--tl-border); border-radius: 999px; text-transform: uppercase; }
.tl-event-dot { position: absolute; right: -10px; top: 4px; width: 22px; height: 22px; border-radius: 50%; background: var(--tl-note); color: #fff; border: 3px solid var(--tl-bg); box-shadow: 0 0 0 1px var(--tl-border); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 800; line-height: 1; z-index: 2; opacity: 0; transform: scale(0.6); transition: opacity 320ms ease, transform 320ms ease; }
.tl-event.is-visible .tl-event-dot { opacity: 1; transform: scale(1); }
.tl-event.is-incident  .tl-event-dot { background: var(--tl-incident); }
.tl-event.is-release   .tl-event-dot { background: var(--tl-release); }
.tl-event.is-milestone .tl-event-dot { background: var(--tl-milestone); }
.tl-event.is-anomaly   .tl-event-dot { background: var(--tl-anomaly); }
.tl-event.is-note      .tl-event-dot { background: var(--tl-note); }
.tl-event.is-anomaly .tl-event-dot::after { content: ""; position: absolute; inset: -6px; border-radius: 50%; border: 2px solid var(--tl-anomaly); opacity: 0; animation: tl-pulse 2.2s ease-out infinite; }
@keyframes tl-pulse { 0% { transform: scale(0.7); opacity: 0.85; } 70% { transform: scale(1.35); opacity: 0; } 100% { transform: scale(1.4); opacity: 0; } }
.tl-event-card { min-width: 0; padding: 0 0 4px; }
.tl-event-kind { display: inline-flex; align-items: center; gap: 6px; font-size: 10px; font-weight: 800; letter-spacing: 0.12em; padding: 3px 9px 3px 8px; border-radius: 999px; text-transform: uppercase; margin-bottom: 10px; color: #fff; background: var(--tl-note); }
.tl-event-kind .tl-kind-glyph { font-size: 11px; line-height: 1; }
.tl-event.is-incident  .tl-event-kind { background: var(--tl-incident); }
.tl-event.is-release   .tl-event-kind { background: var(--tl-release); }
.tl-event.is-milestone .tl-event-kind { background: var(--tl-milestone); }
.tl-event.is-anomaly   .tl-event-kind { background: var(--tl-anomaly); }
.tl-event.is-note      .tl-event-kind { background: var(--tl-note); }
.tl-event-title { font-family: var(--tl-display-font); font-size: 19px; font-weight: 700; margin: 0 0 8px; line-height: 1.3; letter-spacing: -0.005em; color: var(--tl-text); }
.tl-event-body { margin: 0 0 12px; color: var(--tl-text-soft); }
.tl-event-body p { margin: 0 0 10px; }
.tl-event-body p:last-child { margin-bottom: 0; }
.tl-event-body code { font-family: var(--tl-mono-font); font-size: 0.92em; background: var(--tl-bg-sunk); padding: 1px 5px; border-radius: 4px; }
.tl-metric-row { display: flex; flex-wrap: wrap; gap: 6px; margin: 4px 0 14px; }
.tl-metric { display: inline-flex; align-items: baseline; gap: 6px; padding: 4px 10px; border-radius: 999px; border: 1px solid var(--tl-border); background: var(--tl-bg); font-size: 12px; }
.tl-metric-label { color: var(--tl-muted); }
.tl-metric-value { font-weight: 700; font-variant-numeric: tabular-nums; font-family: var(--tl-mono-font); }
.tl-quote { border-left: 3px solid var(--tl-border-strong); padding: 10px 16px; margin: 12px 0; background: var(--tl-bg-soft); border-radius: 0 var(--tl-radius-sm) var(--tl-radius-sm) 0; font-size: 14px; }
.tl-quote blockquote { margin: 0; font-style: italic; color: var(--tl-text); }
.tl-quote blockquote::before { content: "\201C"; }
.tl-quote blockquote::after { content: "\201D"; }
.tl-quote cite { display: block; margin-top: 6px; font-size: 12px; color: var(--tl-muted); font-style: normal; }
.tl-ba { display: grid; grid-template-columns: 1fr auto 1fr; gap: 14px 18px; align-items: stretch; padding: 16px 18px; border: 1px solid var(--tl-border); background: var(--tl-bg-soft); border-radius: var(--tl-radius); margin: 14px 0 10px; }
.tl-ba-col { display: flex; flex-direction: column; gap: 4px; padding: 4px 0; }
.tl-ba-col.is-after { align-items: flex-end; text-align: right; }
.tl-ba-label { font-size: 10px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--tl-muted); font-weight: 700; }
.tl-ba-metric { font-size: 11px; color: var(--tl-text-soft); font-weight: 600; }
.tl-ba-value { font-size: 28px; font-weight: 700; font-variant-numeric: tabular-nums; font-family: var(--tl-mono-font); line-height: 1.05; color: var(--tl-text); }
.tl-ba-unit { font-size: 13px; color: var(--tl-muted); margin-left: 4px; font-weight: 500; font-family: var(--tl-body-font); }
.tl-ba-arrow { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 4px; font-weight: 700; min-width: 84px; }
.tl-ba-arrow.is-up { color: var(--tl-up); }
.tl-ba-arrow.is-down { color: var(--tl-down); }
.tl-ba-arrow.is-flat { color: var(--tl-flat); }
.tl-ba-glyph { font-size: 26px; line-height: 1; }
.tl-ba-delta { display: inline-block; padding: 2px 8px; border-radius: 999px; background: var(--tl-bg); border: 1px solid currentColor; font-family: var(--tl-mono-font); font-variant-numeric: tabular-nums; font-size: 12px; font-weight: 700; white-space: nowrap; }
.tl-ba-caption { grid-column: 1 / -1; margin: 6px 0 0; padding-top: 10px; font-size: 12px; color: var(--tl-text-soft); border-top: 1px dashed var(--tl-border); }
.tl-spark { display: flex; flex-direction: column; gap: 6px; margin: 12px 0 4px; padding: 10px 12px; background: var(--tl-bg); border: 1px solid var(--tl-border); border-radius: var(--tl-radius-sm); }
.tl-spark svg { display: block; width: 100%; max-width: 280px; height: 36px; }
.tl-spark figcaption { font-size: 12px; color: var(--tl-text-soft); line-height: 1.45; }
.tl-empty { padding: 40px 24px; text-align: center; color: var(--tl-muted); border: 1px dashed var(--tl-border); border-radius: var(--tl-radius); background: var(--tl-bg-soft); font-size: 14px; }
@media (max-width: 1024px) { :root { --tl-spine: 64px; --tl-content-max: 100%; } .tl-shell { padding: 28px 24px 72px; } }
@media (max-width: 640px) {
  :root { --tl-spine: 32px; --tl-gap: 14px; }
  body { font-size: 14px; }
  .tl-shell { padding: 20px 14px 64px; }
  .tl-doc-title { font-size: 24px; }
  .tl-doc-header { gap: 12px; }
  .tl-doc-meta { text-align: left; }
  .tl-bookend { grid-template-columns: 1fr 1fr; padding: 16px; gap: 12px; }
  .tl-bookend-value { font-size: 22px; }
  .tl-bookend-mid { grid-column: 1 / -1; flex-direction: row; gap: 8px; }
  .tl-event { padding: 14px 0 18px; }
  .tl-event-date { padding-right: 8px; }
  .tl-event-date-short { font-size: 11px; }
  .tl-event-date-full { display: none; }
  .tl-event-date-range { font-size: 9px; padding: 1px 4px; }
  .tl-event-dot { width: 16px; height: 16px; right: -8px; font-size: 9px; }
  .tl-event-title { font-size: 17px; }
  .tl-ba { grid-template-columns: 1fr; gap: 10px; padding: 14px; }
  .tl-ba-col.is-after { align-items: flex-start; text-align: left; }
  .tl-ba-arrow { flex-direction: row; min-width: 0; justify-content: flex-start; }
  .tl-ba-glyph { font-size: 22px; }
  .tl-ba-value { font-size: 24px; }
}
@media (prefers-reduced-motion: reduce) {
  html { scroll-behavior: auto; }
  .tl-event-dot { opacity: 1 !important; transform: none !important; transition: none !important; }
  .tl-event.is-anomaly .tl-event-dot::after { animation: none !important; opacity: 0 !important; }
  .tl-progress > span { transition: none !important; }
}
a:focus-visible, .tl-skip:focus-visible { outline: 2px solid var(--tl-release); outline-offset: 2px; border-radius: 3px; }
@media print {
  :root { --tl-spine: 80px; }
  .tl-progress, .tl-skip { display: none !important; }
  .tl-shell { max-width: 100%; padding: 0; }
  body { font-size: 10.5pt; color: #000; background: #fff; }
  a { color: #000; text-decoration: none; }
  .tl-doc-header { border-bottom: 1px solid #000; }
  .tl-bookend { background: transparent; border: 1px solid #000; }
  .tl-event { break-inside: avoid; page-break-inside: avoid; }
  .tl-event.is-milestone { break-before: page; page-break-before: always; }
  .tl-event:first-child.is-milestone { break-before: auto; page-break-before: auto; }
  .tl-track::before { background: #000 !important; opacity: 0.3; }
  .tl-event-dot { background: #fff !important; color: #000 !important; border: 1.5px solid #000 !important; box-shadow: none !important; opacity: 1 !important; transform: none !important; }
  .tl-event.is-anomaly .tl-event-dot::after { display: none !important; }
  .tl-event-kind { color: #000 !important; background: transparent !important; border: 1px solid #000; }
  .tl-ba { background: transparent; border: 1px solid #000; }
  .tl-spark { background: transparent; border: 1px solid #000; }
  .tl-ba-delta { background: transparent !important; }
}
</style>
</head>
<body>
<a href="#tl-first-anomaly" class="tl-skip">Skip to first anomaly</a>
<a href="#tl-track" class="tl-skip" style="left:auto;">Skip to timeline</a>

<div class="tl-progress" aria-hidden="true"><span id="tl-progress-bar"></span></div>

<div class="tl-shell">
  <header class="tl-doc-header">
    <div>
      {% if eyebrow %}<p class="tl-doc-eyebrow">{{ eyebrow }}</p>{% endif %}
      <h1 class="tl-doc-title">{{ title }}</h1>
      {% if subtitle %}<p class="tl-doc-subtitle">{{ subtitle }}</p>{% endif %}
    </div>
    <div class="tl-doc-meta">
      {% if generated_at %}Generated <time datetime="{{ generated_at }}">{{ generated_at }}</time><br>{% endif %}
      Timezone <span class="tl-tz">{{ timezone or "UTC" }}</span>
    </div>
  </header>

  {% if start_metric or end_metric or trend_summary or series_sparkline_svg %}
  <section class="tl-bookend" aria-label="Series summary">
    {% if start_metric %}
    <div class="tl-bookend-stat">
      <span class="tl-bookend-label">{{ start_metric.label }}</span>
      <span class="tl-bookend-value">{{ start_metric.value }}{% if start_metric.unit %}<span class="tl-bookend-unit">{{ start_metric.unit }}</span>{% endif %}</span>
    </div>
    {% else %}<div></div>{% endif %}

    <div class="tl-bookend-mid" aria-hidden="true">
      <span class="tl-bookend-arrow">&rarr;</span>
      <span class="tl-bookend-span">over time</span>
    </div>

    {% if end_metric %}
    <div class="tl-bookend-stat is-right">
      <span class="tl-bookend-label">{{ end_metric.label }}</span>
      <span class="tl-bookend-value">{{ end_metric.value }}{% if end_metric.unit %}<span class="tl-bookend-unit">{{ end_metric.unit }}</span>{% endif %}</span>
    </div>
    {% else %}<div></div>{% endif %}

    {% if series_sparkline_svg %}
    <figure class="tl-spark-wide" role="img" aria-label="Series trend sparkline">
      {{ series_sparkline_svg|safe }}
    </figure>
    {% endif %}

    {% if trend_summary %}
    <p class="tl-bookend-trend"><strong>Trend.</strong> {{ trend_summary }}</p>
    {% endif %}
  </section>
  {% endif %}

  {% if not events %}
  <div class="tl-empty">No events in this timeline yet.</div>
  {% else %}
  {# -- find first anomaly index for skip-link -- #}
  {% set ns = namespace(first_anomaly=None) %}
  {% for ev in events %}{% if ev.kind == "anomaly" and ns.first_anomaly is none %}{% set ns.first_anomaly = loop.index %}{% endif %}{% endfor %}

  <ol class="tl-track" id="tl-track">
  {% for ev in events %}
    {% set kind = ev.kind if ev.kind in ["incident","release","milestone","anomaly","note"] else "note" %}
    {% set glyph = {"incident":"⚠","release":"▲","milestone":"★","anomaly":"✦","note":"●"}[kind] %}
    {% set kind_label = kind|upper %}
    {% set is_first_anomaly = (kind == "anomaly" and loop.index == ns.first_anomaly) %}
    <li>
    <article class="tl-event is-{{ kind }}" id="ev-{{ loop.index }}"{% if is_first_anomaly %} data-first-anomaly="true"{% endif %}>
      {% if is_first_anomaly %}<a id="tl-first-anomaly" tabindex="-1" aria-hidden="true" style="position:absolute;top:-24px;"></a>{% endif %}
      <div class="tl-event-date">
        <div class="tl-event-date-short">{{ ev.short_date or ev.date }}</div>
        {% if ev.full_date %}
        <time class="tl-event-date-full" datetime="{{ ev.date }}{% if ev.time %}T{{ ev.time }}{% if ':' not in ev.time %}:00{% endif %}{% endif %}">{{ ev.full_date }}{% if ev.time %} &middot; {{ ev.time }}{% endif %} {{ timezone or "UTC" }}</time>
        {% else %}
        <time class="tl-event-date-full" datetime="{{ ev.date }}">{{ ev.date }} {{ timezone or "UTC" }}</time>
        {% endif %}
        {% if ev.end_date and ev.end_date != ev.date %}
        <span class="tl-event-date-range" title="Date range: {{ ev.date }} – {{ ev.end_date }}">spans {{ ev.span_label or "multi-day" }}</span>
        {% endif %}
        <span class="tl-event-dot" aria-hidden="true" title="{{ kind_label }}">{{ glyph }}</span>
      </div>
      <div class="tl-event-card">
        <span class="tl-event-kind" aria-label="Event kind: {{ kind_label }}"><span class="tl-kind-glyph" aria-hidden="true">{{ glyph }}</span>{{ kind_label }}</span>
        <h2 class="tl-event-title">{{ ev.title }}</h2>

        {% if ev.body_html %}
        <div class="tl-event-body">{{ ev.body_html|safe }}</div>
        {% endif %}

        {% if ev.metrics %}
        <div class="tl-metric-row">
          {% for m in ev.metrics %}
            <span class="tl-metric"><span class="tl-metric-label">{{ m.label }}</span><span class="tl-metric-value">{{ m.value }}{% if m.unit %} {{ m.unit }}{% endif %}</span></span>
          {% endfor %}
        </div>
        {% endif %}

        {% if ev.quote %}
        <div class="tl-quote"><blockquote>{{ ev.quote.text }}</blockquote><cite>&mdash; {{ ev.quote.speaker }}</cite></div>
        {% endif %}

        {% if ev.before_after %}
        {% set ba = ev.before_after %}
        {% set delta_raw = ba.after - ba.before %}
        {% set delta_pct = ((delta_raw / ba.before) * 100) if ba.before not in [0, 0.0] else 0 %}
        {% set dir = "is-up" if delta_raw > 0 else ("is-down" if delta_raw < 0 else "is-flat") %}
        {% set arrow_glyph = "&uarr;" if delta_raw > 0 else ("&darr;" if delta_raw < 0 else "&rarr;") %}
        {% set sign = "+" if delta_raw > 0 else "" %}
        <div class="tl-ba" role="group" aria-label="Before and after: {{ ba.metric }}">
          <div class="tl-ba-col">
            <span class="tl-ba-label">Before</span>
            <span class="tl-ba-metric">{{ ba.metric }}</span>
            <span class="tl-ba-value">{{ ba.before }}{% if ba.unit %}<span class="tl-ba-unit">{{ ba.unit }}</span>{% endif %}</span>
          </div>
          <div class="tl-ba-arrow {{ dir }}">
            <span class="tl-ba-glyph" aria-hidden="true">{{ arrow_glyph|safe }}</span>
            <span class="tl-ba-delta">{{ sign }}{{ "%g"|format(delta_raw) }}{% if ba.unit %} {{ ba.unit }}{% endif %}{% if delta_pct %} &middot; {{ sign }}{{ "%.0f"|format(delta_pct) }}%{% endif %}</span>
          </div>
          <div class="tl-ba-col is-after">
            <span class="tl-ba-label">After</span>
            <span class="tl-ba-metric">{{ ba.metric }}</span>
            <span class="tl-ba-value">{{ ba.after }}{% if ba.unit %}<span class="tl-ba-unit">{{ ba.unit }}</span>{% endif %}</span>
          </div>
          <p class="tl-ba-caption">{% if ba.caption %}{{ ba.caption }}{% else %}{{ ba.metric }} went from {{ ba.before }} to {{ ba.after }}{% if ba.unit %} {{ ba.unit }}{% endif %} ({{ sign }}{{ "%g"|format(delta_raw) }}{% if delta_pct %}, {{ sign }}{{ "%.0f"|format(delta_pct) }}%{% endif %}).{% endif %}</p>
        </div>
        {% endif %}

        {% if ev.sparkline_svg %}
        <figure class="tl-spark" role="img" aria-label="{{ ev.sparkline_caption or 'Metric trend for this event' }}">
          {{ ev.sparkline_svg|safe }}
          {% if ev.sparkline_caption %}<figcaption>{{ ev.sparkline_caption }}</figcaption>{% endif %}
        </figure>
        {% endif %}
      </div>
    </article>
    </li>
  {% endfor %}
  </ol>
  {% endif %}
</div>

<script>
(function(){
  // 1. Reading-progress bar — single scroll listener, rAF-throttled.
  var bar = document.getElementById('tl-progress-bar');
  var ticking = false;
  function update(){
    var h = document.documentElement;
    var max = h.scrollHeight - h.clientHeight;
    var pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
    if (bar) bar.style.width = pct.toFixed(1) + '%';
    ticking = false;
  }
  function onScroll(){
    if (!ticking) { requestAnimationFrame(update); ticking = true; }
  }
  document.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);
  update();

  // 2. Dot scroll-in — single IntersectionObserver for ALL events.
  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        if (e.isIntersecting) {
          e.target.classList.add('is-visible');
          io.unobserve(e.target);
        }
      });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.05 });
    document.querySelectorAll('.tl-event').forEach(function(el){ io.observe(el); });
  } else {
    document.querySelectorAll('.tl-event').forEach(function(el){ el.classList.add('is-visible'); });
  }
})();
</script>
</body>
</html>
